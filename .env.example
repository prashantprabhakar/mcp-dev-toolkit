# Copy this file to .env and fill in your values
# .env is gitignored — never commit it

# Brave Search API — required for search_web tool
# Get one at: https://brave.com/search/api/
BRAVE_API_KEY=

# GitHub personal access token — optional, avoids rate limits on fetch_github_readme
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=

# ── HTTP transport auth ────────────────────────────────────────────────────────
# Only required when running with --transport sse or --transport streamable-http.
# stdio transport (Claude Desktop / Claude Code) does not use these.
#
# Generate tokens:  python -c "import secrets; print(secrets.token_hex(32))"
#
# MCP_READ_TOKEN  → mcp:read              — read-only tools only
# MCP_WRITE_TOKEN → mcp:read mcp:write    — also unlocks write_file
# MCP_ADMIN_TOKEN → mcp:read mcp:write mcp:admin — also unlocks run_command
#
# Pass as:  Authorization: Bearer <token>
MCP_READ_TOKEN=
MCP_WRITE_TOKEN=
MCP_ADMIN_TOKEN=

# Override if running on a non-default host/port (used in WWW-Authenticate headers)
MCP_SERVER_URL=http://127.0.0.1:8000
